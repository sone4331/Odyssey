* text=auto
*.cs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.csv text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf

# Enable these rules when Git LFS is installed for portfolio-owned binary assets.
*.fbx filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text

